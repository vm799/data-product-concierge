# ============================================================================
# APIM Gateway Configuration
# ============================================================================
APIM_TOKEN_ENDPOINT=https://api-gateway.yourfirm.com/oauth2/token
APIM_CLIENT_ID=your_client_id_here
APIM_CLIENT_SECRET=your_client_secret_here
APIM_SCOPE=collibra.read collibra.write snowflake.write
APIM_SUBSCRIPTION_KEY=your_subscription_key_here
APIM_BASE_URL=https://api-gateway.yourfirm.com

