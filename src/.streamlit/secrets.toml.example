# ============================================================
# Streamlit Cloud Secrets
# ============================================================
# Copy this file's contents into Streamlit Cloud → App Settings → Secrets
# These map to the same env vars in .env.example
# See: https://docs.streamlit.io/deploy/streamlit-community-cloud/deploy-your-app/secrets-management
# ============================================================

# APIM Gateway
APIM_TOKEN_ENDPOINT = "https://api-gateway.yourfirm.com/oauth2/token"
APIM_CLIENT_ID = ""
APIM_CLIENT_SECRET = ""
APIM_SCOPE = "collibra.read collibra.write snowflake.write"
APIM_SUBSCRIPTION_KEY = ""
APIM_BASE_URL = "https://api-gateway.yourfirm.com"

# Collibra
COLLIBRA_INSTANCE_URL = "https://yourfirm.collibra.com"
DATA_PRODUCT_TYPE_ID = ""
SOURCE_SYSTEM_TYPE_ID = ""
BUSINESS_DOMAIN_TYPE_ID = ""
COLLIBRA_OWNER_ROLE_ID = ""
COLLIBRA_STEWARD_ROLE_ID = ""
COLLIBRA_DRAFT_STATUS_ID = ""

# LLM Provider
LLM_PROVIDER = "openai"

# LLM routing via APIM gateway (enterprise — set true for Azure OpenAI behind APIM)
# When LLM_VIA_APIM=true, reuses existing APIM_BASE_URL/CLIENT_ID/CLIENT_SECRET/SUBSCRIPTION_KEY
LLM_VIA_APIM = "false"
APIM_OPENAI_DEPLOYMENT = "gpt-4o"
APIM_OPENAI_API_VERSION = "2024-02-01"

# Direct OpenAI fallback (local dev only — not used when LLM_VIA_APIM=true)
OPENAI_API_KEY = ""
OPENAI_MODEL = "gpt-4o"

# PostgreSQL (use a cloud-hosted Postgres e.g. Supabase, Neon, Railway)
DATABASE_URL = "postgresql://user:password@host:5432/dbname"

# Firm branding
FIRM_NAME = "Your Asset Management Firm"
